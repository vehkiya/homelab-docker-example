# ==============================================================================
# Core Homelab Environment Configuration (.env)
# ==============================================================================

# 📁 Global Paths
# The absolute path on your host machine where configuration data will be saved
BASE_DIR=/home/user/homelab

# 🌐 Domain Configuration
# Your registered domain name (e.g., example.com)
DOMAIN=yourdomain.com

# 🔌 Port Bindings
# Standard HTTP (Port 80) and HTTPS (Port 443) bindings for the reverse proxy
WEB_PORT=80
WEBSECURE_PORT=443

# 🔐 Tailscale VPN Configuration
# Provide an ephemeral or reusable Auth Key from your Tailscale Admin Console (Settings -> Keys)
TAILSCALE_AUTH_KEY=tskey-auth-kXxxXXxxXxxx-xxxxxxxxxxxxxxxxxxxxxxxxx

# 🛡️ Traefik Reverse Proxy & Let's Encrypt (ACME) Settings
# Email address used by Let's Encrypt for registration and expiration warnings
ACME_EMAIL=you@example.com

# The identifier token for your certificate resolver (Matches the keys used in compose.yml)
CERT_RESOLVER=cloudflare

# Your specific DNS provider code used by Traefik for the preferred DNS-01 challenge
DNS_PROVIDER=cloudflare

# Public upstream DNS nameservers Traefik queries to verify challenge TXT propagation
DNS_RESOLVERS=1.1.1.1:53,8.8.8.8:53

# 🔑 Registrar-Specific API Credentials
# These environment variables are read by Traefik to automate DNS record modification.
# Settings below vary based on your chosen DNS_PROVIDER (This example is for Cloudflare):
CLOUDFLARE_DNS_API_TOKEN=your_secret_cloudflare_api_token_here
CLOUDFLARE_EMAIL=you@example.com